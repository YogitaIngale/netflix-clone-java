<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Get Premium</title>
<link rel="stylesheet" href="/css/style.css">
<style>
.plans{
display:flex;
justify-content:center;
gap:30px;
margin-top:100px;
}

.plan{
background:#111;
padding:30px;
border-radius:15px;
width:250px;
text-align:center;
transition:0.3s;
}

.plan:hover{
transform:scale(1.05);
}

.plan h2{
color:red;
}

.plan button{
margin-top:15px;
padding:10px 20px;
background:red;
border:none;
color:white;
cursor:pointer;
}
</style>
</head>
<body>

<div class="nav">
<div class="logo">NETFLIX</div>
</div>

<h1 style="text-align:center;margin-top:80px;">Choose Your Plan</h1>

<div class="plans">

<div class="plan">
<h2>Basic</h2>
<p>480p Quality</p>
<p>1 Device</p>
<button onclick="selectPlan('BASIC')">Select</button>
</div>

<div class="plan">
<h2>Standard</h2>
<p>720p Quality</p>
<p>2 Devices</p>
<button onclick="selectPlan('STANDARD')">Select</button>
</div>

<div class="plan">
<h2>Premium</h2>
<p>1080p Quality</p>
<p>4 Devices</p>
<button onclick="selectPlan('PREMIUM')">Select</button>
</div>

</div>

<script src="/js/premium.js"></script>

</body>
</html>