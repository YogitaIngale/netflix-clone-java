package com.yogita.netflix.controller;

import java.io.File;
import java.io.IOException;
import com.yogita.netflix.model.Movie;
import com.yogita.netflix.model.User;
import com.yogita.netflix.service.MovieService;
import com.yogita.netflix.service.UploadLogService;
import jakarta.servlet.http.HttpSession;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

@Controller
@RequestMapping("/admin")
public class AdminController {

    @Autowired
    private MovieService movieService;

    @Autowired
    private UploadLogService logService;

    // Show admin dashboard
    @GetMapping("/dashboard")
    public String dashboard(HttpSession session, Model model,
                            @RequestParam(value="message", required=false) String message) {
        User admin = (User) session.getAttribute("user");
        if(admin == null || !"ADMIN".equals(admin.getRole())) {
            return "redirect:/admin/login";
        }

        model.addAttribute("movies", movieService.getAllMovies());
        model.addAttribute("message", message); // optional success message
        return "admin"; // Thymeleaf template
    }

    // Add movie
    @PostMapping("/add")
    public String addMovie(
            @RequestParam String title,
            @RequestParam String description,
            @RequestParam("posterFile") MultipartFile posterFile,
            @RequestParam String trailer,
            @RequestParam String category,
            HttpSession session,
            Model model) throws IOException {

        User admin = (User) session.getAttribute("user");
        if(admin == null || !"ADMIN".equals(admin.getRole())) {
            return "redirect:/admin/login";
        }

        Movie movie = new Movie();
        movie.setTitle(title);
        movie.setDescription(description);
        movie.setTrailer(trailer);
        movie.setCategory(category);

        // Save poster to server
        if(!posterFile.isEmpty()){
            String uploadDir = "uploads/"; // folder inside your project
            File uploadFolder = new File(uploadDir);
            if(!uploadFolder.exists()) uploadFolder.mkdirs();

            String filename = System.currentTimeMillis() + "_" + posterFile.getOriginalFilename();
            File file = new File(uploadDir + filename);
            posterFile.transferTo(file);

            movie.setPoster("/" + uploadDir + filename); // relative path for HTML
        }

        Movie saved = movieService.addMovie(movie);

        logService.logUpload(admin.getId().intValue(), saved.getId());

        // Reload dashboard with success message
        model.addAttribute("movies", movieService.getAllMovies());
        model.addAttribute("message", "Movie added successfully!");
        return "admin";
    }

    // Delete movie
    @GetMapping("/delete/{id}")
    public String deleteMovie(@PathVariable Integer id, HttpSession session, Model model){
        User admin = (User) session.getAttribute("user");
        if(admin == null || !"ADMIN".equals(admin.getRole())) return "redirect:/admin/login";

        movieService.deleteMovie(id);

        // Reload dashboard with success message
        model.addAttribute("movies", movieService.getAllMovies());
        model.addAttribute("message", "Movie deleted successfully!");
        return "admin";
    }
}