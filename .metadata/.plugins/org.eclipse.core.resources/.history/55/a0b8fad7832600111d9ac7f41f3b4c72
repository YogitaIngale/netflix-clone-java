<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Choose Plan</title>

<style>
body{
background:black;
color:white;
font-family:Arial;
text-align:center;
}

.plans{
display:flex;
justify-content:center;
gap:30px;
margin-top:100px;
}

.plan{
background:#111;
padding:30px;
border-radius:15px;
width:250px;
}

button{
margin-top:15px;
padding:10px 20px;
background:red;
border:none;
color:white;
cursor:pointer;
}
</style>
</head>

<body>

<h1>Choose Your Plan</h1>

<div class="plans">

<div class="plan">
<h2>Basic</h2>
<p>1 Device</p>
<button onclick="selectPlan('BASIC')">Select</button>
</div>

<div class="plan">
<h2>Standard</h2>
<p>2 Devices</p>
<button onclick="selectPlan('STANDARD')">Select</button>
</div>

<div class="plan">
<h2>Premium</h2>
<p>4 Devices</p>
<button onclick="selectPlan('PREMIUM')">Select</button>
</div>

</div>

<script src="/js/premium.js"></script>

</body>
</html>